# Datasets and extracted media.
# Track directory placeholders only; ignore all actual contents.
/data/**
!/data/**/
!/data/**/.gitkeep
*.mp4
*.avi
*.mkv
*.webm
*.tar
*.tar.gz
*.tgz
*.zip
*.7z

# Model weights and generated artifacts.
# Track directory placeholders only; ignore all actual contents.
/checkpoints/**
!/checkpoints/.gitkeep
/outputs/**
!/outputs/**/
!/outputs/**/.gitkeep
/wandb/**
!/wandb/.gitkeep
*.pth
*.pt
*.ckpt
*.safetensors
*.onnx
*.npy
*.npz

# Logs and experiment trackers
*.log
events.out.tfevents.*

# Python environments and caches
/.venv/
.env
.env.*
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/

# Editors and operating-system metadata
.vscode/
.idea/
.DS_Store
Thumbs.db

# Temporary downloads and files
*.part
*.tmp
*.swp
*~
